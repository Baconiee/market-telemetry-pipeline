# ==============================================================================
# Crypto Market Telemetry Ingestion Pipeline - Environment Configuration Template
# ==============================================================================
# Instructions: Copy this file to a new file named '.env' in the same directory
# and update the values to match your local environment configuration.
# ==============================================================================

# Storage Layer Settings (PostgreSQL Engine configuration)
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=market_warehouse
POSTGRES_HOST=market_db
POSTGRES_PORT=5432

# Management Layer Settings (Airflow Framework Identity configuration)
AIRFLOW_OWNER=your_name
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=ChooseASecurePassword123!
AIRFLOW_UID=1000